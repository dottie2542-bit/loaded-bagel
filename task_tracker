import json
import os
import sys

# 1. Setup the file
DATA_FILE = 'tasks.json'

def load_tasks():
    if not os.path.exists(DATA_FILE):
        return []
    with open(DATA_FILE, 'r') as f:
        return json.load(f)

def save_tasks(tasks):
    with open(DATA_FILE, 'w') as f:
        json.dump(tasks, f, indent=4)

# 2. The Command Logic
def main():
    # Check if you typed anything at all
    if len(sys.argv) < 2:
        print("Usage: python task_cli.py [add|list|update|delete]")
        return

    command = sys.argv[1]
    tasks = load_tasks()

    if command == "add":
        # python task_cli.py add "Task name"
        description = sys.argv[2]
        new_id = len(tasks) + 1
        tasks.append({"id": new_id, "description": description, "status": "todo"})
        save_tasks(tasks)
        print(f"Success: Added task {new_id}")

    elif command == "list":
        # python task_cli.py list
        if not tasks:
            print("The list is empty.")
        for t in tasks:
            print(f"ID: {t['id']} | {t['description']} [{t['status']}]")

    elif command == "delete":
        # python task_cli.py delete 1
        task_id = int(sys.argv[2])
        tasks = [t for t in tasks if t['id'] != task_id]
        save_tasks(tasks)
        print(f"Success: Deleted task {task_id}")

    elif command == "update":
        # python task_cli.py update 1 "New Name"
        task_id = int(sys.argv[2])
        new_desc = sys.argv[3]
        for t in tasks:
            if t['id'] == task_id:
                t['description'] = new_desc
        save_tasks(tasks)
        print(f"Success: Updated task {task_id}")

# 3. Start the program
if __name__ == "__main__":
    main()
